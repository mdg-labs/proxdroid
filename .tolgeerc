{
  "$schema": "https://docs.tolgee.io/cli-schema.json",
  "projectId": 2,
  "apiUrl": "https://tolgee.mdg-labs.dev",
  "format": "FLUTTER_ARB",
  "strictNamespace": false,
  "push": {
    "filesTemplate": "./lib/l10n/app_{languageTag}.arb",
    "languages": ["en", "de"]
  },
  "pull": {
    "path": "./lib/l10n",
    "fileStructureTemplate": "app_{languageTag}.arb"
  }
}
